# AWS IAM Credenciales del Usuario Tecnico (desarrollador-agent)
AWS_ACCESS_KEY_ID=TU_ACCESS_KEY_ID_AQUI
AWS_SECRET_ACCESS_KEY=TU_SECRET_ACCESS_KEY_AQUI

# Configuracion Regional de Infraestructura
AWS_REGION=us-east-2

# ID unico de la Base de Conocimientos de Bedrock (RAG FIRA)
AWS_KNOWLEDGE_BASE_ID=BWWFT7NT0O

# LLM en Bedrock
AGENT_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
AGENT_TEMPERATURE=0

# Twilio (WhatsApp)
SID_TWILO=your-twilio-sid
AUTH_TOKEN_TWILO=your-twilio-auth-token
NUMERO_TWILO=+15551234567

# Banxico SIE API (TIIE en vivo)
BANXICO_TOKEN=your-banxico-token

# Base de datos
DATABASE_URL=sqlite:///ceres.db

# LangSmith (opcional, para trazabilidad)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=ceres-agente

# Resend (notificaciones por correo)
RESEND_API_KEY=re_xxxxxxxxxxxx
CORREO_DESTINO=dualyrf@gmail.com
CORREO_REMITENTE=Ceres <contacto@dashclass.studio>

# Cloudflare Tunnel (para exponer webhook local)
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
